#!/usr/bin/env bash
# pls-engine: Streams to stderr, outputs single clean command to stdout
set -uo pipefail

CONFIG_DIR="$HOME/.config/pls"
CONFIG_FILE="$CONFIG_DIR/config.json"

_DEBUG_MODE=0
if [[ "${1:-}" == "--debug" ]]; then
  _DEBUG_MODE=1
  shift
fi

debug() { [ "${_DEBUG_MODE}" -eq 1 ] && echo -e "\033[0;33m[DEBUG]\033[0m $*" >&2; }

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  VERSION_FILE="/usr/share/doc/pls-cli-git/VERSION"
  if [[ -f "$VERSION_FILE" ]]; then
    cat "$VERSION_FILE"
  else
    if command -v git &> /dev/null && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      git describe --tags --always --dirty
    else
      echo "Version info not available. Installed via AUR? Try 'pacman -Q pls-cli-git'"
    fi
  fi
  exit 0
fi

USER_PROMPT="${1:-}"
CURRENT_SHELL="${2:-bash}"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
BLUE="\033[0;34m"
NC="\033[0m"

error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
info() { echo -e "${BLUE}[INFO]${NC} $*" >&2; }

FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")

create_default_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" << EOL
{
  "provider": "ollama",
  "model": "gemma3:4b",
  "ollama_url": "http://localhost:11434",
  "temperature": 0.1,
  "system_prompt": "You are a shell command generator. Output exactly one single-line command for the requested task. No explanations, no markdown, no code fences, no language tags. Only the raw command.",
  "shell_specific_prompts": {
    "fish": "Generate Fish shell commands using Fish-specific syntax (e.g., 'set' for variables, Fish conditionals).",
    "bash": "Generate Bash shell commands using POSIX syntax.",
    "zsh": "Generate Zsh shell commands using Zsh-specific features if beneficial."
  }
}
EOL
}

show_thinking() {
  local pid=$1
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r${BLUE}${FRAMES[i]} Generating...${NC}" >&2
    ((i = (i + 1) % ${#FRAMES[@]}))
    sleep 0.1
  done
  printf "\r\033[K" >&2
}

stream_response() {
  local model="$1" url="$2" prompt="$3" temp="$4"
  local json_payload
  json_payload=$(jq -n \
    --arg model "$model" \
    --arg prompt "$prompt" \
    --argjson stream true \
    --argjson temp "$temp" \
    '{model: $model, prompt: $prompt, stream: $stream, options: {temperature: $temp}}')
  
  debug "JSON Payload to Ollama:"
  [ "${_DEBUG_MODE}" -eq 1 ] && echo "$json_payload" | jq . >&2

  local response_file
  response_file=$(mktemp)
  
  if ! curl -s --head "$url" | head -n 1 | grep "200 OK" > /dev/null; then
      error "Cannot connect to Ollama at $url. Is 'ollama serve' running?"
      rm -f "$response_file"
      return 1
  fi
  
  curl -s "$url/api/generate" -d "$json_payload" > "$response_file" &
  local curl_pid=$!

  show_thinking "$curl_pid"
  wait "$curl_pid"
  
  if first_line=$(head -n 1 "$response_file"); ollama_error=$(echo "$first_line" | jq -r '.error // empty'); [ -n "$ollama_error" ]; then
    error "Ollama API error: $ollama_error"
    rm -f "$response_file"
    return 1
  fi

  local command=""
  while IFS= read -r line; do
    local part
    part=$(echo "$line" | jq -r '.response // empty')
    if [ -n "$part" ]; then
      printf "%s" "$part" >&2
      command+="$part"
    fi
    local done_flag
    done_flag=$(echo "$line" | jq -r '.done // false')
    if [ "$done_flag" = "true" ]; then break; fi
  done < "$response_file"

  printf "\n" >&2
  debug "Raw command from model: '$command'"

  if [ -z "$command" ]; then
    error "No command generated by the model."
    rm -f "$response_file"
    return 1
  fi
  rm -f "$response_file"
  
  command=$(echo "$command" | sed -e 's/`//g' -e 's/^shell//' -e 's/^bash//' -e 's/^fish//' -e 's/^zsh//' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
  
  echo "$command"
}

stream_response_openai() {
  local model="$1" url="$2" system_prompt="$3" user_prompt="$4" temp="$5"
  local json_payload
  json_payload=$(jq -n \
    --arg model "$model" \
    --arg system "$system_prompt" \
    --arg user "$user_prompt" \
    --argjson stream true \
    --argjson temp "$temp" \
    '{model: $model, messages: [{role: "system", content: $system}, {role: "user", content: $user}], stream: $stream, temperature: $temp}')

  debug "JSON Payload to OpenAI-compatible API:"
  [ "${_DEBUG_MODE}" -eq 1 ] && echo "$json_payload" | jq . >&2

  local response_file
  response_file=$(mktemp)

  if ! curl -s --max-time 5 "$url/v1/models" > /dev/null 2>&1; then
    error "Cannot connect to API at $url. Is the server running?"
    rm -f "$response_file"
    return 1
  fi

  curl -s "$url/v1/chat/completions" \
    -H "Content-Type: application/json" \
    -d "$json_payload" > "$response_file" &
  local curl_pid=$!

  show_thinking "$curl_pid"
  wait "$curl_pid"

  local api_error
  api_error=$(head -n 1 "$response_file" | jq -r '.error.message // empty' 2>/dev/null)
  if [ -n "$api_error" ]; then
    error "API error: $api_error"
    rm -f "$response_file"
    return 1
  fi

  local command=""
  while IFS= read -r line; do
    line="${line#data: }"
    [ -z "$line" ] && continue
    [ "$line" = "[DONE]" ] && break
    local part
    part=$(echo "$line" | jq -r '.choices[0].delta.content // empty' 2>/dev/null)
    if [ -n "$part" ]; then
      printf "%s" "$part" >&2
      command+="$part"
    fi
  done < "$response_file"

  printf "\n" >&2
  debug "Raw command from model: '$command'"

  if [ -z "$command" ]; then
    error "No command generated by the model."
    rm -f "$response_file"
    return 1
  fi
  rm -f "$response_file"

  command=$(echo "$command" | sed -e 's/`//g' -e 's/^shell//' -e 's/^bash//' -e 's/^fish//' -e 's/^zsh//' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

  echo "$command"
}

debug "User prompt received: '$USER_PROMPT'"
debug "Shell context: $CURRENT_SHELL"

[ -z "$USER_PROMPT" ] && { error "Usage: pls-engine \"<prompt>\" [shell]"; exit 1; }
command -v jq >/dev/null || { error "jq required"; exit 1; }
command -v curl >/dev/null || { error "curl required"; exit 1; }

[ ! -f "$CONFIG_FILE" ] && create_default_config

PROVIDER=$(jq -r '.provider // "ollama"' "$CONFIG_FILE")
MODEL=$(jq -r '.model' "$CONFIG_FILE")
API_URL=$(jq -r '.api_url // .ollama_url' "$CONFIG_FILE")
TEMPERATURE=$(jq -r '.temperature' "$CONFIG_FILE")
SYSTEM_PROMPT=$(jq -r '.system_prompt' "$CONFIG_FILE")
SHELL_SPECIFIC=$(jq -r ".shell_specific_prompts.\"$CURRENT_SHELL\" // empty" "$CONFIG_FILE")

debug "Provider: $PROVIDER"
debug "Model: $MODEL"
debug "API URL: $API_URL"
debug "Temperature: $TEMPERATURE"

info "Generating command for $CURRENT_SHELL..."

if [ "$PROVIDER" = "openai" ]; then
  FULL_SYSTEM_PROMPT="$SYSTEM_PROMPT $SHELL_SPECIFIC"
  if ! SUGGESTED_CMD=$(stream_response_openai "$MODEL" "$API_URL" "$FULL_SYSTEM_PROMPT" "User request: $USER_PROMPT" "$TEMPERATURE"); then
    error "Failed to generate command."
    exit 1
  fi
else
  FINAL_PROMPT="$SYSTEM_PROMPT $SHELL_SPECIFIC User request: $USER_PROMPT"
  if ! SUGGESTED_CMD=$(stream_response "$MODEL" "$API_URL" "$FINAL_PROMPT" "$TEMPERATURE"); then
    error "Failed to generate command."
    exit 1
  fi
fi

echo "$SUGGESTED_CMD"
